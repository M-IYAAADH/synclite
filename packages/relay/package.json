{
  "name": "@synclite/relay",
  "version": "0.1.0",
  "description": "Self-hostable WebSocket relay server for Synclite",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "synclite-relay": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --watch dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.0",
    "jsonwebtoken": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "vitest": "^1.4.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
