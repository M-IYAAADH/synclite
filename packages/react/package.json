{
  "name": "@nexsync/react",
  "version": "0.1.0",
  "description": "React hooks and provider for NexSync — offline-first sync",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@nexsync/core": ">=0.1.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@nexsync/core": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/node": "^20.0.0",
    "react": "^18.3.0",
    "typescript": "^5.4.0"
  },
  "files": ["dist"],
  "license": "MIT"
}
